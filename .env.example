# ─────────────────────────────────────────────────────────────
# Apex Revenue System — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit your .env file to source control.
# ─────────────────────────────────────────────────────────────

# Google Gemini AI (required for /genesis, /ai/leads, /ai/analyze)
# Get your key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Coinbase Commerce (required for /checkout/<plan> and /webhook/coinbase)
# Create an account at: https://commerce.coinbase.com
COINBASE_API_KEY=your_coinbase_commerce_api_key_here
COINBASE_WEBHOOK_SECRET=your_coinbase_webhook_secret_here

# Public base URL of your deployment (used for Coinbase redirect URLs)
# For Railway: https://<your-service>.up.railway.app
BASE_URL=https://apex-revenue-system.up.railway.app

# Railway deployment token (used by GitHub Actions to deploy)
# Generate at: https://railway.app/account/tokens
RAILWAY_TOKEN=your_railway_token_here

# Flask development only — do NOT set in production
# PORT is set automatically by Railway
PORT=5000

# ─────────────────────────────────────────────────────────────
# Edge Node Configuration (Pixel 10)
# ─────────────────────────────────────────────────────────────

# Bearer token the Pixel 10 presents when connecting to the controller.
# Generate a strong random token and share it with the device securely.
PIXEL_10_NODE_TOKEN=your_pixel_10_node_token_here

# HMAC secret for verifying webhook payloads from/to edge nodes.
EDGE_WEBHOOK_SECRET=your_edge_webhook_hmac_secret_here
